# ──────────────────────────────────────────────────────────────
# LogiGuard AI — Environment Variables
# Copy to .env and fill in secrets before running.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Port 5435 avoids conflicts with locally installed PostgreSQL
DATABASE_URL=postgresql+asyncpg://logiguard:logiguard_dev@127.0.0.1:5435/logiguard

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (S3 / MinIO) ──────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=logiguard-documents
S3_REGION=us-east-1

# ── LLM Provider ─────────────────────────────────────────────
# Option 1: OpenAI (production)
# OPENAI_API_KEY=sk-proj-your-key-here
# LLM_MODEL=gpt-4o

# Option 2: OpenRouter (free testing)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-4-maverick:free

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Application ───────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# ── OCR (optional — only needed for PDF invoice processing) ──
TESSERACT_CMD=tesseract
POPPLER_PATH=

